# ============================================================
# Personalized Networking Assistant - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit the real .env file to version control.

# ----------------------------------------------------------
# OpenRouter API (required)
# Get your free API key at: https://openrouter.ai/keys
# ----------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model to use.
# Recommended free-tier models:
#   openai/gpt-oss-120b:free           (GPT-OSS 120B - user preferred)
#   meta-llama/llama-3.3-70b-instruct:free
#   nvidia/nemotron-3-super-120b-a12b:free
#   deepseek/deepseek-r1:free
#   google/gemma-4-31b-it:free
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# OpenRouter base URL (do not change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Your site URL (used in OpenRouter request headers - optional)
YOUR_SITE_URL=http://localhost:8501
YOUR_SITE_NAME=Personalized-Networking-Assistant

# ----------------------------------------------------------
# FastAPI Server
# ----------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# ----------------------------------------------------------
# Generation Parameters
# ----------------------------------------------------------
NUM_STARTERS=3
MAX_TOKENS=500
TEMPERATURE=0.8

# ----------------------------------------------------------
# Wikipedia
# ----------------------------------------------------------
WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_USER_AGENT=PersonalizedNetworkingAssistant/1.0

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
